func MakeSystemState(store adt.Store, c cid.Cid) (system.State, error) {
    if name, av, ok := actors.GetActorMetaByCode(c); ok {
		if name != manifest.SystemKey {
			return nil, fmt.Errorf("actor code is not system: %s", name)
		}

		switch av {

		case actorstypes.Version8:
			return system.MakeState(store, actorstypes.Version8, cid.Undef)
        case actorstypes.Version9:
			return system.MakeState(store, actorstypes.Version9, cid.Undef)
		}
	}

    {{ range $vi := .Vers -}}
    {{if lt .Ver 8 -}}
    if c == builtin{{ .Ver }}.SystemActorCodeID {
        return system.MakeState(store, actorstypes.Version{{ .Ver }}, cid.Undef)
    }
    {{ end -}}
    {{ end }}

    return nil, fmt.Errorf("not system actor code: %v", c)
}
