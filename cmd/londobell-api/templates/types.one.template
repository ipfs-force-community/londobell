func IsStoragePowerActor(c cid.Cid) bool {
    if name, _, ok := actors.GetActorMetaByCode(c); ok {
		if name != manifest.PowerKey {
			return false
		}
		return true
	}

    {{ range $vi := .Vers -}}
    {{if lt .Ver 8 -}}
    if c == builtin{{ .Ver }}.StoragePowerActorCodeID {
    		return true
    }
    {{ end -}}
    {{ end }}

    return false
}

